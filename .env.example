# Analytics Platform — Environment Variables
# Copy to .env and fill in values

# ── Database ──────────────────────────────────────────────────
# Path to your dbt-generated DuckDB file
# Run `dbt build` in your dbt project first
DUCKDB_PATH=analytics.duckdb

# ── AI Insights (optional) ────────────────────────────────────
# Without this, the app uses rule-based insights (still works)
ANTHROPIC_API_KEY=

# ── API ───────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ── Frontend ──────────────────────────────────────────────────
VITE_API_URL=http://localhost:8000
